# Storm Tracker — Environment Configuration
# Copy to .env and fill in values

NWS_USER_AGENT=StormTracker/1.0 (your-domain.com contact@your-domain.com)
NWS_API_BASE=https://api.weather.gov
NWS_POLL_INTERVAL=60

REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=120

SQLITE_DB_PATH=./data/storm_tracker.db

DEFAULT_LAT=39.5
DEFAULT_LON=-84.5
DEFAULT_LOCATION_NAME=Ohio Valley

LOG_LEVEL=INFO
