[Unit]
Description=Storm Tracker — Severe Weather Decision Support
After=network.target redis-server.service
Wants=redis-server.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/storm-tracker
Environment=PATH=/opt/storm-tracker/venv/bin:/usr/bin:/bin
ExecStart=/opt/storm-tracker/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8119 --workers 1
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
